{
  "name": "ohmytoken",
  "version": "0.1.0",
  "description": "Real-time AI agent token usage monitor for Claude, Codex & Gemini",
  "main": "dist-electron/main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && tsc -p tsconfig.electron.json && vite build && electron-builder --mac",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "ensure:electron": "node scripts/ensure-sqlite-build.js electron",
    "ensure:node": "node scripts/ensure-sqlite-build.js node",
    "electron:dev": "npm run ensure:electron && concurrently \"vite\" \"tsc -p tsconfig.electron.json -w\" \"electron .\"",
    "start": "npm run ensure:electron && npm run build:electron && electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p packages/oht-cli/tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "npm run ensure:node && vitest run --config vitest.config.electron.ts",
    "test:db": "npm run ensure:node && vitest run --config vitest.config.electron.ts",
    "test:e2e": "npm run build:electron && npx playwright test",
    "test:e2e:headed": "npm run build:electron && npx playwright test --headed",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "mercleodev",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mercleodev/ohmytoken.git"
  },
  "dependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "better-sqlite3": "^12.6.2",
    "framer-motion": "^12.33.0",
    "js-tiktoken": "^1.0.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.7.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.0.8",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.ohmytoken.monitor",
    "productName": "OhMyToken",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ]
  }
}
